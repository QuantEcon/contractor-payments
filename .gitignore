__pycache__/
*.py[cod]
.pytest_cache/
.venv/
*.egg-info/
.DS_Store

# Local working clones of contractor repos. Cloned here by
# onboarding/new-contractor.py so admin tools can operate against
# multiple contractor repos from inside this engine repo without
# chdir-ing elsewhere. Each subdirectory is an independent git
# checkout of its respective QuantEcon/contractor-{handle} repo.
# Anchored to repo root so it doesn't shadow onboarding/contractors/.
/contractors/

# Contractor input YAMLs consumed by onboarding/new-contractor.py via
# --config. May contain personal info (email, postal address), so kept
# admin-private. The committed `example.yml` is the documented stub.
onboarding/contractors/*
!onboarding/contractors/example.yml
